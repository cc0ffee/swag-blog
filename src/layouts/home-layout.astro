---
import '@/styles/global.css'
import '@/styles/typography.css'

import Head from '@/components/head.astro'
import HomeSidebar from '@/components/home-sidebar.astro'
import HomeTopbar from '@/components/home-topbar.astro'
import { SITE } from '@/consts'
---

<!doctype html>
<html
  class="bg-white text-[var(--home-brown)] scheme-light"
  lang={SITE.locale}
  data-sidebar-collapsed="true"
>
  <Head>
    <slot name="head" />
  </Head>
  <body class="font-sans antialiased">
    <HomeSidebar />
    <HomeTopbar />
    <div
      class="home-main min-h-screen transition-[margin-left] duration-300 ease-in-out"
      style="margin-left: var(--home-sidebar-width); padding-top: var(--home-topbar-height);"
    >
      <slot />
    </div>
  </body>
</html>

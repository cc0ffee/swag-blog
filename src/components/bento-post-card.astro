---
import Link from '@/components/link.astro'
import { parseAuthors } from '@/lib/data-utils'
import { formatDateISO } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  entry: CollectionEntry<'blog'>
  variant: 'pinned' | 'vertical' | 'horizontal'
}

const { entry, variant } = Astro.props
const authors = await parseAuthors(entry.data.authors ?? [])
const primaryAuthor = authors[0]
const formattedDate = formatDateISO(entry.data.date)
const tags = entry.data.tags ?? []
const href = `/blog/${entry.id}`
---

{
  variant === 'pinned' ? (
    <article class="group relative h-full overflow-hidden shadow-sm ring-1 ring-black/5">
      <div
        class="pointer-events-none absolute top-0 left-0 z-10 flex size-10 items-center justify-center bg-red-500 text-white shadow-md"
        style="clip-path: polygon(0 0, 100% 0, 0 100%);"
        aria-hidden="true"
      >
        <Icon name="lucide:pin" class="absolute top-1.5 left-1.5 size-3.5 -rotate-45" />
      </div>

      <Link href={href} class="grid h-full min-h-72 md:grid-cols-2">
        <div class="relative min-h-48 overflow-hidden bg-[var(--home-beige)]">
          {entry.data.image ? (
            <Image
              src={entry.data.image}
              alt={entry.data.title}
              width={800}
              height={500}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          ) : (
            <div class="flex h-full min-h-48 items-center justify-center bg-[var(--home-beige)]">
              <Icon name="lucide:image" class="size-10 text-[var(--home-brown)]/20" />
            </div>
          )}
        </div>

        <div class="flex flex-col bg-[#4a4545] p-5 text-white md:p-6">
          {tags.length > 0 && (
            <ul class="mb-3 flex flex-wrap gap-1.5" role="list">
              {tags.slice(0, 4).map((tag) => (
                <li>
                  <span class="bg-white/15 px-2.5 py-0.5 text-xs text-white/90">
                    {tag}
                  </span>
                </li>
              ))}
            </ul>
          )}

          <h3 class="mb-3 line-clamp-2 text-xl leading-snug font-semibold md:text-2xl">
            {entry.data.title}
          </h3>

          <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-white/75">
            {primaryAuthor && (
              <span class="flex items-center gap-1.5">
                <img
                  src={primaryAuthor.avatar}
                  alt=""
                  width="18"
                  height="18"
                  class="size-[18px] rounded-full object-cover"
                />
                {primaryAuthor.name}
              </span>
            )}
            <span class="flex items-center gap-1">
              <Icon name="lucide:calendar" class="size-3.5" />
              {formattedDate}
            </span>
            <span class="flex items-center gap-1">
              <Icon name="lucide:folder" class="size-3.5" />
            </span>
          </div>

          {entry.data.description && (
            <p class="line-clamp-3 flex-1 text-sm leading-relaxed text-white/70">
              {entry.data.description}
            </p>
          )}

          {entry.data.location && (
            <p class="mt-4 flex items-center justify-end gap-1 text-xs text-white/50">
              <Icon name="lucide:map-pin" class="size-3" />
              {entry.data.location}
            </p>
          )}
        </div>
      </Link>
    </article>
  ) : (
    <article class="group h-full overflow-hidden bg-white shadow-sm ring-1 ring-black/5">
      <Link
        href={href}
        class:list={[
          variant === 'horizontal'
            ? 'grid h-full min-h-52 md:grid-cols-2'
            : 'flex h-full flex-col',
        ]}
      >
        <div
          class:list={[
            'relative overflow-hidden bg-[var(--home-beige)]',
            variant === 'horizontal' ? 'min-h-40' : 'aspect-[4/3]',
          ]}
        >
          {entry.data.image ? (
            <Image
              src={entry.data.image}
              alt={entry.data.title}
              width={600}
              height={400}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          ) : (
            <div class="flex h-full min-h-40 items-center justify-center">
              <Icon name="lucide:image" class="size-8 text-[var(--home-brown)]/20" />
            </div>
          )}
        </div>

        <div
          class:list={[
            'flex flex-col',
            variant === 'horizontal'
              ? 'justify-center p-5'
              : 'flex-1 p-4',
          ]}
        >
          {tags.length > 0 && (
            <ul class="mb-2 flex flex-wrap gap-1.5" role="list">
              {tags.slice(0, 3).map((tag) => (
                <li>
                  <span class="bg-[var(--home-beige)] px-2 py-0.5 text-xs text-[var(--home-brown)]/70">
                    {tag}
                  </span>
                </li>
              ))}
            </ul>
          )}

          <h3 class="mb-2 line-clamp-2 text-base leading-snug font-semibold text-[var(--home-brown)]">
            {entry.data.title}
          </h3>

          <div class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--home-brown)]/55">
            {primaryAuthor && (
              <span class="flex items-center gap-1.5">
                <img
                  src={primaryAuthor.avatar}
                  alt=""
                  width="16"
                  height="16"
                  class="size-4 rounded-full object-cover"
                />
                {primaryAuthor.name}
              </span>
            )}
            <span class="flex items-center gap-1">
              <Icon name="lucide:calendar" class="size-3.5" />
              {formattedDate}
            </span>
            <span class="flex items-center gap-1">
              <Icon name="lucide:folder" class="size-3.5" />
            </span>
          </div>

          {variant === 'horizontal' && entry.data.description && (
            <p class="mt-2 line-clamp-2 text-xs leading-relaxed text-[var(--home-brown)]/60">
              {entry.data.description}
            </p>
          )}
        </div>
      </Link>
    </article>
  )
}

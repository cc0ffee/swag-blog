---
import { cn, getHeadingMargin } from '@/lib/utils'
import type { TOCSection } from '@/lib/data-utils'
import { getParentId, isSubpost } from '@/lib/data-utils'

interface Props {
  sections: TOCSection[]
  currentPostId: string
}

const { sections, currentPostId } = Astro.props
const isCurrentSubpost = isSubpost(currentPostId)
const parentId = isCurrentSubpost ? getParentId(currentPostId) : currentPostId
---

{
  sections.length > 0 && (
    <nav
      id="post-toc-container"
      class="sticky top-[calc(var(--home-topbar-height)+1.5rem)] hidden h-fit w-44 shrink-0 self-start lg:block xl:w-52"
      aria-label="Table of contents"
    >
      <ul class="flex list-none flex-col gap-1 border-l border-transparent">
        {sections.map((section, index) => {
          const isFirstSubpost =
            section.type === 'subpost' &&
            (index === 0 || sections[index - 1].type === 'parent')

          return (
            <>
              {isFirstSubpost && (
                <li class="mt-3 mb-1 px-3 text-[10px] tracking-widest text-[var(--home-brown)]/35 uppercase">
                  Subposts
                </li>
              )}

              {section.type === 'parent' ? (
                section.headings.map((heading) => (
                  <li
                    class={cn(
                      'border-l-2 border-transparent pl-3 transition-colors',
                      getHeadingMargin(heading.depth),
                    )}
                  >
                    <a
                      href={
                        isCurrentSubpost
                          ? `/blog/${parentId}#${heading.slug}`
                          : `#${heading.slug}`
                      }
                      class="block py-1 text-sm leading-snug text-[var(--home-brown)]/45 transition-colors hover:text-[var(--home-brown)]"
                      data-post-toc-link={heading.slug}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))
              ) : (
                <>
                  <li class="border-l-2 border-transparent pl-3">
                    <a
                      href={
                        section.subpostId === currentPostId
                          ? '#post-title'
                          : `/blog/${section.subpostId}`
                      }
                      class={cn(
                        'block py-1 text-xs font-medium transition-colors',
                        section.subpostId === currentPostId
                          ? 'text-[var(--home-brown)]/70'
                          : 'text-[var(--home-brown)]/40 hover:text-[var(--home-brown)]/60',
                      )}
                      data-post-toc-link={
                        section.subpostId === currentPostId
                          ? 'top'
                          : `${section.subpostId}-top`
                      }
                    >
                      {section.title}
                    </a>
                  </li>
                  {section.headings.map((heading) => (
                    <li
                      class={cn(
                        'border-l-2 border-transparent pl-3 transition-colors',
                        getHeadingMargin(heading.depth),
                      )}
                    >
                      <a
                        href={
                          section.subpostId === currentPostId
                            ? `#${heading.slug}`
                            : `/blog/${section.subpostId}#${heading.slug}`
                        }
                        class="block py-1 text-sm leading-snug text-[var(--home-brown)]/45 transition-colors hover:text-[var(--home-brown)]"
                        data-post-toc-link={
                          section.subpostId === currentPostId
                            ? heading.slug
                            : `${section.subpostId}-${heading.slug}`
                        }
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </>
              )}
            </>
          )
        })}
      </ul>
    </nav>
  )
}

<script>
  const HEADER_OFFSET = 120

  function resetActiveLinks() {
    document.querySelectorAll('[data-post-toc-link]').forEach((link) => {
      const item = link.closest('li')
      item?.classList.remove('border-red-400')
      link.classList.remove('text-[var(--home-brown)]', 'font-medium')
      link.classList.add('text-[var(--home-brown)]/45')
    })
  }

  function setActiveLink(id: string) {
    const link = document.querySelector(`[data-post-toc-link="${id}"]`)
    if (!link) return

    const item = link.closest('li')
    item?.classList.add('border-red-400')
    link.classList.add('text-[var(--home-brown)]', 'font-medium')
    link.classList.remove('text-[var(--home-brown)]/45')
  }

  function buildRegions() {
    const headings = Array.from(
      document.querySelectorAll<HTMLElement>(
        '.post-prose h2, .post-prose h3, .post-prose h4, .post-prose h5, .post-prose h6',
      ),
    )

    return headings.map((heading, index) => {
      const nextHeading = headings[index + 1]
      return {
        id: heading.id,
        start: heading.offsetTop,
        end: nextHeading ? nextHeading.offsetTop : document.body.scrollHeight,
      }
    })
  }

  function getActiveId(regions: { id: string; start: number; end: number }[]) {
    const scrollPos = window.scrollY + HEADER_OFFSET

    for (let index = regions.length - 1; index >= 0; index -= 1) {
      if (scrollPos >= regions[index].start) {
        return regions[index].id
      }
    }

    return regions[0]?.id ?? null
  }

  let regions: { id: string; start: number; end: number }[] = []
  let activeId: string | null = null

  function handleScroll() {
    if (regions.length === 0) return

    const nextActiveId = getActiveId(regions)
    if (nextActiveId && nextActiveId !== activeId) {
      activeId = nextActiveId
      resetActiveLinks()
      setActiveLink(activeId)
    }
  }

  function initPostToc() {
    regions = buildRegions()
    activeId = null
    handleScroll()
    window.addEventListener('scroll', handleScroll, { passive: true })
    window.addEventListener('resize', () => {
      regions = buildRegions()
      handleScroll()
    })
  }

  function cleanupPostToc() {
    window.removeEventListener('scroll', handleScroll)
    regions = []
    activeId = null
  }

  initPostToc()
  document.addEventListener('astro:page-load', initPostToc)
  document.addEventListener('astro:before-swap', cleanupPostToc)
</script>

---
import Link from '@/components/link.astro'
import { HOME_MUSIC, HOME_SOCIAL_LINKS, SITE } from '@/consts'
import { getSortedTags } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

const tags = await getSortedTags()

const socialColors: Record<string, string> = {
  RSS: 'text-orange-500',
  GitHub: 'text-[var(--home-brown)]',
  Telegram: 'text-sky-500',
  Bilibili: 'text-sky-400',
}

const socialIcons: Record<string, string> = {
  RSS: 'lucide:rss',
  GitHub: 'lucide:github',
  Telegram: 'lucide:send',
  Bilibili: 'lucide:tv',
}
---

<aside class="flex flex-col gap-5 lg:sticky lg:top-[calc(var(--home-topbar-height)+1.5rem)] lg:w-64 lg:shrink-0">
  <div class="overflow-hidden bg-white shadow-sm ring-1 ring-black/5">
    <img
      src="/static/avatar.jpg"
      alt=""
      width="256"
      height="256"
      class="aspect-square w-full object-cover"
    />
    <div class="p-4 text-center">
      <p class="font-mono text-lg tracking-wide text-[var(--home-brown)]">
        {SITE.author}
      </p>
      <p class="mt-2 text-xs leading-relaxed text-[var(--home-brown)]/60">
        {SITE.description}
      </p>
      <ul class="mt-4 flex justify-center gap-2" role="list">
        {
          HOME_SOCIAL_LINKS.map(({ href, label }) => (
            <li>
              <Link
                href={href}
                external={href.startsWith('http')}
                aria-label={label}
                title={label}
                class={`inline-flex size-8 items-center justify-center bg-[var(--home-beige)] transition-opacity hover:opacity-80 ${socialColors[label] ?? 'text-[var(--home-brown)]'}`}
              >
                <Icon name={socialIcons[label] ?? 'lucide:link'} class="size-3.5" />
              </Link>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="bg-white p-4 shadow-sm ring-1 ring-black/5">
    <div class="mb-3 flex items-center gap-2 text-sm text-[var(--home-brown)]/70">
      <Icon name="lucide:music" class="size-4" />
      <span>{HOME_MUSIC.title}</span>
    </div>

    <div class="flex items-center gap-3">
      <div class="relative size-14 shrink-0">
        <div class="absolute inset-0 animate-spin border-2 border-[var(--home-brown)]/10 [animation-duration:8s]">
        </div>
        <img
          src={HOME_MUSIC.albumArt}
          alt=""
          width="56"
          height="56"
          class="size-14 object-cover p-1"
        />
      </div>

      <div class="min-w-0 flex-1">
        <p class="truncate text-sm font-medium text-[var(--home-brown)]">
          {HOME_MUSIC.track}
        </p>
        <div class="mt-2 h-1 overflow-hidden bg-[var(--home-beige)]">
          <div
            class="h-full bg-[var(--home-brown)]/40"
            style={`width: ${HOME_MUSIC.progress}%`}
          >
          </div>
        </div>
        <div class="mt-1 flex items-center justify-between text-[10px] text-[var(--home-brown)]/45">
          <span>{HOME_MUSIC.current}</span>
          <span>{HOME_MUSIC.duration}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white p-4 shadow-sm ring-1 ring-black/5">
    <ul class="flex flex-wrap gap-x-3 gap-y-2" role="list">
      {
        tags.map(({ tag, count }) => (
          <li>
            <Link
              href={`/tags/${tag}`}
              class="text-sm text-[var(--home-brown)]/65 transition-colors hover:text-[var(--home-brown)]"
            >
              {tag}
              <sup class="ml-0.5 text-[10px] text-[var(--home-brown)]/40">
                {count}
              </sup>
            </Link>
          </li>
        ))
      }
    </ul>
  </div>
</aside>

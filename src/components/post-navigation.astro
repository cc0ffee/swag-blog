---
import Link from '@/components/link.astro'
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'

const { newerPost, olderPost, parentPost } = Astro.props
const isSubpost = !!parentPost
---

<nav
  class={cn(
    'mx-auto grid w-full max-w-3xl grid-cols-1 gap-3',
    isSubpost ? 'sm:grid-cols-3' : 'sm:grid-cols-2',
  )}
>
  <Link
    href={olderPost ? `/blog/${olderPost.id}` : '#'}
    class={cn(
      'group flex items-center gap-3 border border-[var(--home-brown)]/10 bg-white px-5 py-3 text-sm transition-colors hover:border-[var(--home-brown)]/20 hover:bg-[var(--home-beige)]/30',
      !olderPost && 'pointer-events-none opacity-40',
    )}
    aria-disabled={!olderPost}
  >
    <Icon
      name="lucide:arrow-left"
      class="size-4 shrink-0 text-[var(--home-brown)]/50 transition-transform group-hover:-translate-x-0.5"
    />
    <span class="truncate text-[var(--home-brown)]/80">
      {
        olderPost?.data.title ||
          (isSubpost ? 'No older subpost' : "You're at the oldest post!")
      }
    </span>
  </Link>

  {
    isSubpost && (
      <Link
        href={parentPost ? `/blog/${parentPost.id}` : '#'}
        class={cn(
          'group flex items-center justify-center gap-2 border border-[var(--home-brown)]/10 bg-white px-5 py-3 text-sm transition-colors hover:border-[var(--home-brown)]/20 hover:bg-[var(--home-beige)]/30',
          !parentPost && 'pointer-events-none opacity-40',
        )}
      >
        <Icon name="lucide:corner-left-up" class="size-4 shrink-0" />
        <span class="truncate">{parentPost?.data.title || 'Parent post'}</span>
      </Link>
    )
  }

  <Link
    href={newerPost ? `/blog/${newerPost.id}` : '#'}
    class={cn(
      'group flex items-center justify-end gap-3 border border-[var(--home-brown)]/10 bg-white px-5 py-3 text-sm transition-colors hover:border-[var(--home-brown)]/20 hover:bg-[var(--home-beige)]/30',
      !newerPost && 'pointer-events-none opacity-40',
    )}
    aria-disabled={!newerPost}
  >
    <span class="truncate text-[var(--home-brown)]/80">
      {
        newerPost?.data.title ||
          (isSubpost ? 'No newer subpost' : "You're at the newest post!")
      }
    </span>
    <Icon
      name="lucide:arrow-right"
      class="size-4 shrink-0 text-[var(--home-brown)]/50 transition-transform group-hover:translate-x-0.5"
    />
  </Link>
</nav>

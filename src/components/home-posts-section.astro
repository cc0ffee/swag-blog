---
import BentoPostCard from '@/components/bento-post-card.astro'
import HomeSidebarWidgets from '@/components/home-sidebar-widgets.astro'
import { SITE } from '@/consts'
import { getBentoLayout, getHomePosts } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

const { pinned, posts, total } = await getHomePosts()
const displayPosts = posts.slice(0, SITE.featuredPostCount)
---

<section class="bg-white px-6 py-12 lg:px-12">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 lg:flex-row lg:items-start">
    <div class="min-w-0 flex-1">
      <div
        class="mb-6 flex items-center gap-3 border-b border-[var(--home-brown)]/10 pb-4"
      >
        <img
          src="/static/avatar.jpg"
          alt=""
          width="32"
          height="32"
          class="size-8 rounded-full object-cover"
        />
        <h2 class="text-2xl font-semibold tracking-widest text-[var(--home-brown)]">
          POST
        </h2>
        <div
          class="ml-auto flex items-center gap-1.5 text-sm text-[var(--home-brown)]/60"
        >
          <Icon name="lucide:bookmark" class="size-4" />
          <span>{total}</span>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-12">
        {
          pinned && (
            <div class="md:col-span-8">
              <BentoPostCard entry={pinned} variant="pinned" />
            </div>
          )
        }

        {
          displayPosts.map((post, index) => {
            const layout = getBentoLayout(index)
            const spanClass =
              layout === 'horizontal' ? 'md:col-span-8' : 'md:col-span-4'

            return (
              <div class={spanClass}>
                <BentoPostCard entry={post} variant={layout} />
              </div>
            )
          })
        }
      </div>
    </div>

    <HomeSidebarWidgets />
  </div>
</section>
